#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/common.sh"

usage() {
  printf 'Usage: scripts/git/integrate-agent <slice>\n'
}

require_agent_branch() {
  branch_exists "$1" || fail "Missing agent branch: $1"
  [[ "$(git rev-list --count "$SPRINT_BRANCH..$1")" -gt 0 ]] || fail "No commits ahead on $1"
}

squash_agent_branch() {
  if ! git merge --squash --no-commit "$1"; then
    fail "Squash merge reported conflicts. Resolve them manually on $SPRINT_BRANCH"
  fi
}

main() {
  local slice branch
  [[ $# -eq 1 ]] || { usage; fail "Expected <slice>"; }
  require_clean_tree
  load_sprint_context
  validate_slice "$1"
  branch="$(agent_branch_name "$1")"
  require_agent_branch "$branch"
  squash_agent_branch "$branch"
  log "Staged squash merge from $branch into $SPRINT_BRANCH"
  git diff --cached --stat
}

main "$@"
